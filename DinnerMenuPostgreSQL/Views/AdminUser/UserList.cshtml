@model List<DinnerMenuPostgreSQL.Entities.ApplicationUser>

@{
    ViewData["Title"] = "Kullanıcılar";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    /* ========================================
           PAGE-SCOPED STYLES — UserList
        ======================================== */
    :root {
        --usr-accent: #3b82f6;
        --usr-accent-soft: rgba(59, 130, 246, 0.10);
        --usr-accent-dark: #1d4ed8;
        --usr-green: #22c55e;
        --usr-green-soft: rgba(34, 197, 94, 0.10);
        --usr-red: #ef4444;
        --usr-red-soft: rgba(239, 68, 68, 0.10);
        --usr-border: #f0ede8;
        --usr-row-hover: #fcfdfe;
        --usr-radius: 12px;
        --usr-avatar-size: 40px;
    }

    /* ---- Page Header ---- */
    .usr-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .usr-page-title {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        font-weight: 700;
        color: #1a1a1a;
        margin: 0 0 4px;
        line-height: 1.2;
    }

    .usr-page-desc {
        font-size: 13.5px;
        color: #888;
        font-weight: 400;
        margin: 0;
    }

    /* ---- Stats Strip ---- */
    .usr-stats-strip {
        display: flex;
        gap: 12px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .stat-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff;
        border: 1px solid var(--usr-border);
        border-radius: 30px;
        padding: 7px 16px 7px 10px;
        font-size: 13px;
        font-weight: 500;
        color: #555;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }

        .stat-pill .pill-icon {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }

        .stat-pill .pill-count {
            font-size: 14px;
            font-weight: 700;
            color: #1a1a1a;
        }

    /* ---- Search & Filter Bar ---- */
    .usr-toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .usr-search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 320px;
    }

        .usr-search-wrap .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
            font-size: 15px;
            pointer-events: none;
        }

    .usr-search-input {
        width: 100%;
        padding: 9px 12px 9px 36px;
        border: 1px solid var(--usr-border);
        border-radius: 10px;
        font-size: 13.5px;
        font-family: 'DM Sans', sans-serif;
        background: #fff;
        color: #1a1a1a;
        outline: none;
        transition: all 0.2s;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }

        .usr-search-input:focus {
            border-color: var(--usr-accent);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
        }

    .usr-filter-select {
        padding: 9px 14px;
        border: 1px solid var(--usr-border);
        border-radius: 10px;
        font-size: 13px;
        font-family: 'DM Sans', sans-serif;
        background: #fff;
        color: #555;
        outline: none;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }

        .usr-filter-select:focus {
            border-color: var(--usr-accent);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
        }

    .usr-result-count {
        margin-left: auto;
        font-size: 12.5px;
        color: #aaa;
        font-weight: 500;
        white-space: nowrap;
    }

    /* ---- Table Container ---- */
    .usr-table-card {
        background: #fff;
        border: 1px solid var(--usr-border);
        border-radius: var(--usr-radius);
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(0,0,0,0.05);
    }

    /* ---- Table ---- */
    .usr-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'DM Sans', sans-serif;
    }

        .usr-table thead tr {
            background: #fafaf8;
            border-bottom: 2px solid var(--usr-border);
        }

        .usr-table thead th {
            padding: 13px 16px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: #aaa;
            text-align: left;
            white-space: nowrap;
            user-select: none;
        }

            .usr-table thead th.col-num {
                width: 48px;
                text-align: center;
            }

            .usr-table thead th.col-status {
                width: 140px;
            }

        /* Body rows */
        .usr-table tbody tr {
            border-bottom: 1px solid #f5f2ee;
            transition: background 0.17s ease, box-shadow 0.17s ease;
            animation: rowFadeIn 0.35s ease both;
        }

            .usr-table tbody tr:last-child {
                border-bottom: none;
            }

            .usr-table tbody tr:hover {
                background: var(--usr-row-hover);
            }

    @@keyframes rowFadeIn {
        from

    {
        opacity: 0;
        transform: translateY(6px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .usr-table tbody td {
        padding: 14px 16px;
        vertical-align: middle;
        font-size: 13.5px;
        color: #333;
    }

        .usr-table tbody td.col-num {
            text-align: center;
            font-size: 12px;
            color: #bbb;
            font-weight: 600;
        }

    /* Row number chip */
    .row-num-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        background: #f5f2ee;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        color: #aaa;
    }

    /* ---- User Details ---- */
    .user-info-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: var(--usr-avatar-size);
        height: var(--usr-avatar-size);
        border-radius: 50%;
        background: var(--usr-accent-soft);
        color: var(--usr-accent-dark);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 14px;
        border: 1px solid rgba(59, 130, 246, 0.2);
        flex-shrink: 0;
    }

    .user-name {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a1a;
        letter-spacing: -0.01em;
    }

    .user-username {
        font-size: 12px;
        color: #888;
        font-weight: 400;
    }

    /* ---- Status Badge ---- */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 11px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.01em;
    }

        .status-badge .badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .status-badge.confirmed {
            background: var(--usr-green-soft);
            color: #16a34a;
            border: 1px solid rgba(34,197,94,0.2);
        }

            .status-badge.confirmed .badge-dot {
                background: var(--usr-green);
                box-shadow: 0 0 0 2px rgba(34,197,94,0.25);
                animation: pulseDot 2s infinite;
            }

        .status-badge.unconfirmed {
            background: var(--usr-red-soft);
            color: #dc2626;
            border: 1px solid rgba(239,68,68,0.2);
        }

            .status-badge.unconfirmed .badge-dot {
                background: var(--usr-red);
            }

    @@keyframes pulseDot {
        0%, 100%

    {
        box-shadow: 0 0 0 2px rgba(34,197,94,0.25);
    }

    50% {
        box-shadow: 0 0 0 4px rgba(34,197,94,0.12);
    }

    }

    /* ---- Empty State ---- */
    .usr-empty {
        padding: 64px 24px;
        text-align: center;
    }

    .usr-empty-icon {
        width: 72px;
        height: 72px;
        background: #f5f2ee;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: #ccc;
        margin: 0 auto 18px;
    }

    .usr-empty-title {
        font-size: 16px;
        font-weight: 700;
        color: #333;
        margin-bottom: 6px;
    }

    .usr-empty-desc {
        font-size: 13.5px;
        color: #aaa;
    }

    /* ---- Pagination ---- */
    .usr-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-top: 1px solid var(--usr-border);
        background: #fafaf8;
        flex-wrap: wrap;
        gap: 10px;
    }

    .pag-info {
        font-size: 12.5px;
        color: #aaa;
        font-weight: 500;
    }

        .pag-info strong {
            color: #555;
        }

    .pag-controls {
        display: flex;
        gap: 4px;
    }

    .pag-btn {
        width: 32px;
        height: 32px;
        border: 1px solid var(--usr-border);
        background: #fff;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        cursor: pointer;
        color: #555;
        transition: all 0.15s;
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        text-decoration: none;
    }

        .pag-btn:hover {
            border-color: var(--usr-accent);
            color: var(--usr-accent-dark);
            background: var(--usr-accent-soft);
        }

        .pag-btn.active {
            background: var(--usr-accent);
            border-color: var(--usr-accent);
            color: #fff;
            box-shadow: 0 2px 8px rgba(59, 130, 246, 0.35);
        }

        .pag-btn:disabled {
            opacity: 0.35;
            cursor: not-allowed;
            pointer-events: none;
        }

    /* ---- Responsive ---- */
    @@media (max-width: 767.98px) {
        .usr-page-header

    {
        flex-direction: column;
        align-items: flex-start;
    }

    .usr-stats-strip {
        gap: 8px;
    }

    .col-num {
        display: none !important;
    }

    .usr-result-count {
        display: none;
    }

    .usr-table thead th, .usr-table tbody td {
        padding: 12px 10px;
    }

    }
</style>

<!-- =====================================================
     PAGE HEADER
===================================================== -->
<div class="usr-page-header">
    <div>
        <h1 class="usr-page-title">
            <i class="bi bi-people-fill me-2" style="color:var(--usr-accent);font-size:20px;vertical-align:middle;"></i>
            Kullanıcı Yönetimi
        </h1>
        <p class="usr-page-desc">Kayıtlı sistem kullanıcılarını listeleyin ve e-posta doğrulama durumlarını kontrol edin.</p>
    </div>
</div>

<!-- =====================================================
     STATS STRIP
===================================================== -->
@{
    var totalCount = Model?.Count ?? 0;
    var confirmedCount = Model?.Count(u => u.EmailConfirmed) ?? 0;
    var unconfirmedCount = totalCount - confirmedCount;
}

<div class="usr-stats-strip">
    <div class="stat-pill">
        <div class="pill-icon" style="background:#f5f2ee;">
            <i class="bi bi-people" style="color:#aaa;"></i>
        </div>
        <span>Toplam Kullanıcı</span>
        <span class="pill-count">@totalCount</span>
    </div>
    <div class="stat-pill">
        <div class="pill-icon" style="background:var(--usr-green-soft);">
            <i class="bi bi-patch-check-fill" style="color:var(--usr-green);"></i>
        </div>
        <span>Onaylı E-posta</span>
        <span class="pill-count" style="color:#16a34a;">@confirmedCount</span>
    </div>
    <div class="stat-pill">
        <div class="pill-icon" style="background:var(--usr-red-soft);">
            <i class="bi bi-exclamation-triangle-fill" style="color:var(--usr-red);"></i>
        </div>
        <span>Onaysız E-posta</span>
        <span class="pill-count" style="color:#dc2626;">@unconfirmedCount</span>
    </div>
</div>

<!-- =====================================================
     TOOLBAR
===================================================== -->
<div class="usr-toolbar">
    <div class="usr-search-wrap">
        <i class="bi bi-search search-icon"></i>
        <input type="text"
               class="usr-search-input"
               id="usrSearchInput"
               placeholder="Ad, kullanıcı adı veya e-posta ara..."
               oninput="filterTable()" />
    </div>
    <select class="usr-filter-select" id="usrStatusFilter" onchange="filterTable()">
        <option value="all">Tüm Onay Durumları</option>
        <option value="confirmed">Onaylandı</option>
        <option value="unconfirmed">Onaylanmadı</option>
    </select>
    <span class="usr-result-count" id="usrResultCount">
        @totalCount kayıt gösteriliyor
    </span>
</div>

<!-- =====================================================
     TABLE CARD
===================================================== -->
<div class="usr-table-card">

    @if (Model == null || !Model.Any())
    {
        <!-- Empty State -->
        <div class="usr-empty">
            <div class="usr-empty-icon">
                <i class="bi bi-person-x"></i>
            </div>
            <div class="usr-empty-title">Henüz kullanıcı bulunmuyor</div>
            <p class="usr-empty-desc">Sisteme kayıtlı herhangi bir kullanıcı bulunamadı.</p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="usr-table" id="usrTable">
                <thead>
                    <tr>
                        <th class="col-num">#</th>
                        <th>Kullanıcı</th>
                        <th>Email</th>
                        <th>Telefon</th>
                        <th class="col-status">Email Durumu</th>
                    </tr>
                </thead>
                <tbody id="usrTableBody">
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var user = Model[i];
                        var isConfirmed = user.EmailConfirmed;
                        var fullName = $"{user.FirstName} {user.LastName}".Trim();
                        var initial = !string.IsNullOrEmpty(user.FirstName) ? user.FirstName.Substring(0, 1).ToUpper() : "U";
                        var searchMeta = $"{fullName} {user.UserName} {user.Email}".ToLower();

                        <tr data-search="@searchMeta"
                            data-status="@(isConfirmed ? "confirmed" : "unconfirmed")"
                            style="animation-delay: @(i * 30)ms;">
                            <!-- Row Number -->
                            <td class="col-num">
                                <span class="row-num-chip">@(i + 1)</span>
                            </td>

                            <!-- User Info Avatar + Name -->
                            <td>
                                <div class="user-info-wrap">
                                    <div class="user-avatar">
                                        @initial
                                    </div>
                                    <div>
                                        <div class="user-name">
                                            @(string.IsNullOrWhiteSpace(fullName) ? "İsimsiz Kullanıcı" : fullName)
                                        </div>
                                        <div class="user-username">@@user.UserName</div>
                                    </div>
                                </div>
                            </td>

                            <!-- Email -->
                            <td>
                                <span style="font-weight: 500; color: #444;">@user.Email</span>
                            </td>

                            <!-- Phone Number -->
                            <td>
                                @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                {
                                    <span style="font-family: monospace; color: #555;">@user.PhoneNumber</span>
                                }
                                else
                                {
                                    <span style="color: #ccc;">—</span>
                                }
                            </td>

                            <!-- Email Status -->
                            <td class="col-status">
                                @if (isConfirmed)
                                {
                                    <span class="status-badge confirmed">
                                        <span class="badge-dot"></span>
                                        Onaylandı
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge unconfirmed">
                                        <span class="badge-dot"></span>
                                        Onaylanmadı
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination Footer -->
        <div class="usr-pagination">
            <div class="pag-info">
                Toplam <strong>@totalCount</strong> kullanıcı
            </div>
            <div class="pag-controls">
                <button class="pag-btn" disabled aria-label="Önceki">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <a href="#" class="pag-btn active">1</a>
                <button class="pag-btn" disabled aria-label="Sonraki">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }

</div>

@section Scripts {
    <script>
        /* ---- Search & Filter ---- */
        function filterTable() {
            const query  = document.getElementById('usrSearchInput').value.toLowerCase().trim();
            const status = document.getElementById('usrStatusFilter').value;
            const rows   = document.querySelectorAll('#usrTableBody tr');
            let visible  = 0;

            rows.forEach(row => {
                const searchMeta = row.dataset.search || '';
                const rowStatus  = row.dataset.status || '';

                const matchQuery  = searchMeta.includes(query);
                const matchStatus = status === 'all' || rowStatus === status;

                if (matchQuery && matchStatus) {
                    row.style.display = '';
                    visible++;
                } else {
                    row.style.display = 'none';
                }
            });

            const countEl = document.getElementById('usrResultCount');
            if (countEl) {
                countEl.textContent = visible + ' kayıt gösteriliyor';
            }
        }
    </script>
}