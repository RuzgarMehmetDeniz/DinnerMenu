@model DinnerMenuPostgreSQL.Entities.Category
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en-US">
    @await Component.InvokeAsync("_MenuHeadComponentPartial")
<body class="body-header1">
    <div class="mask-nav-2">
        @await Component.InvokeAsync("_MenuMobileComponentPartial")
    </div>
    @await Component.InvokeAsync("_MenuNavbarComponentPartial")

    <!-- TOP IMAGE HEADER -->
    <section class="topSingleBkg topPageBkg">
        <div class="item-content-bkg">
            <div class="item-img" style="background-image:url('@Model.CategoryImageUrl');"></div>
            <div class="inner-desc">
                <h1 class="post-title single-post-title">@Model.CategoryName</h1>
                <span class="post-subtitle">@Model.CategoryName kategorisindeki lezzetlerimiz</span>
            </div>
        </div>
    </section>
    <!-- /TOP IMAGE HEADER -->
    <!-- CATEGORY PRODUCTS -->
    <section class="menu-1col-content">
        <div class="container">
            <div class="row">
                <div class="col-md-10 offset-md-1">
                    <a href="/Category/Index" class="back-to-categories">
                        <i class="fa fa-angle-left"></i> Tüm Kategoriler
                    </a>

                    @{
                        var activeProducts = Model.Products?.Where(p => p.Status).ToList();
                    }

                    @if (activeProducts == null || !activeProducts.Any())
                    {
                        <div class="categ-name">
                            <h2>Bu kategoride henüz ürün bulunmuyor.</h2>
                        </div>
                    }
                    else
                    {
                        <div class="menu-holder menu-1col">
                            @foreach (var product in activeProducts)
                            {
                                <div class="menu-post clearfix">
                                    <div class="menu-post-img">
                                        <a href="@product.ImageUrl" class="lightbox" title="@product.ProductName">
                                            <img width="400" height="400" src="@product.ImageUrl" alt="@product.ProductName" title="@product.ProductName" />
                                        </a>
                                    </div>
                                    <div class="menu-post-desc">
                                        <h4>
                                            <span class="menu-title">@product.ProductName</span>
                                            <span class="menu-dots"></span>
                                            <span class="menu-price">₺ @product.Price.ToString("F2")</span>
                                        </h4>
                                        <div class="menu-text">@product.Description</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
    <!-- /CATEGORY PRODUCTS -->
    @await Component.InvokeAsync("_MenuFooterComponentPartial")
    @await Component.InvokeAsync("_MenuScriptsComponentPartial")
</body>
</html>

<style>
    .back-to-categories {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: 'Poppins', sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: #888;
        text-decoration: none;
        margin-bottom: 20px;
    }

        .back-to-categories:hover {
            color: #2b2b2b;
        }
</style>